# VAP Production Crontab
# Install: crontab /home/bigbox/code/verus-agent-platform/deploy/crontab.example
#
# Set your webhook URL for alerts:
ALERT_WEBHOOK_URL=https://discord.com/api/webhooks/YOUR_WEBHOOK_ID/YOUR_WEBHOOK_TOKEN
VAP_DIR=/home/bigbox/code/verus-agent-platform
LOG_DIR=/home/bigbox/code/verus-agent-platform/logs

# ─── Database Backup (every 6 hours, keep last 28) ───
0 */6 * * * cd $VAP_DIR && DB_PATH=./data/verus-platform.db BACKUP_DIR=./backups MAX_BACKUPS=28 ./scripts/backup-db.sh >> $LOG_DIR/backup.log 2>&1

# ─── Service Health Monitor (every minute) ───
* * * * * $VAP_DIR/deploy/monitor-services.sh >> $LOG_DIR/monitor.log 2>&1

# ─── Log Rotation (daily at 2am) ───
0 2 * * * truncate -s 0 $LOG_DIR/*.log 2>/dev/null

# ─── Prune old backups (weekly, keep last 7 days) ───
0 4 * * 0 find $VAP_DIR/backups -name "*.db.gz" -mtime +7 -delete >> $LOG_DIR/maintenance.log 2>&1
